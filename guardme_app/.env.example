# Google Maps API Key (required) — get from https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=your-google-maps-key

# Alan AI Voice Key (optional)
ALAN_VOICE_KEY=

# Backend API URL — change based on your platform:
#   Android emulator: http://10.0.2.2:8080
#   Android device:    http://<your-lan-ip>:8080
#   iOS simulator:     http://localhost:8080
#   Linux desktop:     http://localhost:8080
#   Chrome web:        http://localhost:8080
API_BASE_URL=http://10.0.2.2:8080

# Anthropic / OpenCode AI endpoint (used for emotion analysis with vision models)
# Note: do NOT include /v1 or /messages here. The SDK appends /v1/messages automatically.
ANTHROPIC_BASE_URL=https://opencode.ai/zen/go
