# JWT Secret (required) — generate with: openssl rand -base64 64
JWT_SECRET=your-base64-secret-here

# Twilio (optional — leave empty to skip SMS/WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SMTP (optional — leave empty to skip email)
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
